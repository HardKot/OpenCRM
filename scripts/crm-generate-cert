#!/bin/bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CERT_DIR="$ROOT_DIR/.devcontainer/nginx/certs"
CRT_FILE="$CERT_DIR/localhost.crt"
KEY_FILE="$CERT_DIR/localhost.key"

mkdir -p "$CERT_DIR"

if ! command -v openssl >/dev/null 2>&1; then
  echo "openssl не найден. Установи openssl и запусти скрипт снова."
  exit 1
fi

echo "Генерация self-signed сертификата для localhost..."

openssl req -x509 -nodes -newkey rsa:2048 -sha256 -days 365 \
  -keyout "$KEY_FILE" \
  -out "$CRT_FILE" \
  -subj "/C=RU/ST=Dev/L=Dev/O=OpenCRM/OU=Dev/CN=localhost" \
  -addext "subjectAltName=DNS:localhost,IP:127.0.0.1"

chmod 600 "$KEY_FILE"
chmod 644 "$CRT_FILE"

echo "Сертификат создан:"
echo "  CRT: $CRT_FILE"
echo "  KEY: $KEY_FILE"