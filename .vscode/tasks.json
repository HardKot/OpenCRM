{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Spring Boot: Run with Remote Debug",
            "type": "shell",
            "command": "cd backend && ./gradlew bootRun --debug-jvm",
            "isBackground": true,
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "group": "Spring Boot"
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*ERROR.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*:.*$",
                    "endsPattern": "^.*Started.*in.*$"
                }
            }
        },
        {
            "label": "React: Start Dev Server",
            "type": "shell",
            "command": "cd frontend && npm start",
            "isBackground": true,
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "group": "React"
            },
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": "^.*ERROR.*$",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*Compiled.*",
                    "endsPattern": "^.*webpack compiled.*$"
                }
            }
        }
    ]
}
