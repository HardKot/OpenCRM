{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Spring Boot: Run",
            "type": "shell",
            "command": "cd backend && ./gradlew bootRun --debug-jvm",
            "isBackground": true,
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "group": "Spring Boot"
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*ERROR.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*:.*$",
                    "endsPattern": "^.*Started.*in.*$"
                }
            }
        },
        {
            "label": "React: Start Dev Server",
            "type": "shell",
            "command": "cd frontend && npm start",
            "isBackground": true,
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "group": "React"
            },
            "problemMatcher": {
                "pattern": [
                    {
                        "regexp": "^.*ERROR.*$",
                        "file": 1,
                        "location": 2,
                        "message": 3
                    }
                ],
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*Compiled.*",
                    "endsPattern": "^.*webpack compiled.*$"
                }
            }
        },
        {
            "label": "Gradle: Build",
            "type": "shell",
            "command": "cd backend && ./gradlew build",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "Build"
            },
            "problemMatcher": [
                "$gradle"
            ]
        },
        {
            "label": "Tests: Spring Boot",
            "type": "shell",
            "command": "cd backend && ./gradlew test",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "Tests"
            },
            "problemMatcher": [
                "$gradle"
            ]
        },
        {
            "label": "Tests: React",
            "type": "shell",
            "command": "cd frontend && npm test",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "Tests"
            },
            "isBackground": true,
            "problemMatcher": [
                "$tsc"
            ]
        }
    ]
}
